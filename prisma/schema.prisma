generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  profile        Profile?
  accounts       Account[]
  sessions       Session[]
  enrollments    Enrollment[]
  certificates   Certificate[]
  payments       Payment[]
  wishlists      Wishlist[]
  notifications  Notification[]
  progress       LearningProgress[]
  auditLogs      AuditLog[]
  newsletterSubs NewsletterSubscriber?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// PROFILES & ROLES
// ============================================

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  fullName     String?
  username     String?  @unique
  phone        String?
  country      String?
  state        String?
  city         String?
  gender       String?
  bio          String?
  avatarUrl    String?
  academicInterests String?
  socialLinks  Json?
  role         UserRole @default(STUDENT)
  status       AccountStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses           Course[]          @relation("InstructorCourses")
  enrollments       Enrollment[]
  certificates      Certificate[]
  payments          Payment[]
  wishlists         Wishlist[]
  notifications     Notification[]
  progress          LearningProgress[]
  userRoles         UserRoleAssignment[]
  storageFiles      StorageFile[]
  newsletterSubs    NewsletterSubscriber?

  @@map("profiles")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  INSTRUCTOR
  COURSE_MANAGER
  STUDENT
  GUEST
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING
  DEACTIVATED
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Permission[]
  userRoles   UserRoleAssignment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  category    String?
  roles       Role[]
  userRoles   UserRoleAssignment[]
  createdAt   DateTime @default(now())

  @@map("permissions")
}

model UserRoleAssignment {
  id           String   @id @default(cuid())
  userId       String
  roleId       String
  assignedBy   String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())

  user       Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission[]

  @@unique([userId, roleId])
  @@map("user_role_assignments")
}

// ============================================
// COURSES
// ============================================

model Course {
  id               String          @id @default(cuid())
  title            String
  slug             String          @unique
  code             String          @unique
  category         String?
  subcategory      String?
  shortDescription String?
  fullDescription  String?         @db.Text
  learningOutcomes String?         @db.Text
  prerequisites    String?         @db.Text
  targetAudience   String?         @db.Text
  difficultyLevel  DifficultyLevel @default(BEGINNER)
  language         String          @default("English")
  durationHours    Int?
  thumbnailUrl     String?
  promoVideoUrl    String?
  price            Decimal         @default(0) @db.Decimal(10, 2)
  currency         String          @default("USD")
  isFree           Boolean         @default(true)
  status           CourseStatus    @default(DRAFT)
  featured         Boolean         @default(false)
  instructorId     String?
  metaTitle        String?
  metaDescription  String?
  tags             String[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  publishedAt      DateTime?

  instructor  Profile?        @relation("InstructorCourses", fields: [instructorId], references: [id])
  lessons     Lesson[]
  enrollments Enrollment[]
  certificates Certificate[]
  payments    Payment[]
  wishlists   Wishlist[]
  learningPathsCourse LearningPathCourse[]

  @@index([status])
  @@index([category])
  @@index([instructorId])
  @@map("courses")
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum CourseStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
  SUSPENDED
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?  @db.Text
  orderIndex  Int      @default(0)
  duration    Int?     // in minutes
  isPreview   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  videos     Video[]
  materials  Material[]
  progress   LearningProgress[]

  @@index([courseId])
  @@map("lessons")
}

model Video {
  id           String       @id @default(cuid())
  lessonId     String
  title        String
  description  String?      @db.Text
  videoUrl     String
  duration     Int?         // in seconds
  thumbnailUrl String?
  provider     VideoProvider @default(SUPABASE)
  storageType  StorageType  @default(URL)
  quality      String?      // e.g., "1080p", "720p"
  orderIndex   Int          @default(0)
  isPublic     Boolean      @default(true)
  views        Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("videos")
}

enum VideoProvider {
  SUPABASE
  AWS_S3
  CLOUDFLARE_R2
  CLOUDFLARE_STREAM
  BUNNY_STREAM
  VIMEO
  YOUTUBE
  GOOGLE_DRIVE
  CUSTOM
}

enum StorageType {
  URL
  FILE
  STREAM
}

model Material {
  id              String        @id @default(cuid())
  lessonId        String
  title           String
  description     String?       @db.Text
  type            MaterialType
  fileUrl         String
  fileSize        Int?          // in bytes
  mimeType        String?
  visibility      Visibility    @default(PUBLIC)
  downloadAllowed Boolean       @default(true)
  orderIndex      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("materials")
}

enum MaterialType {
  PDF
  SLIDES
  NOTE
  ASSIGNMENT
  ARTICLE
  EBOOK
  DATASET
  CODE
  EXTERNAL
}

enum Visibility {
  PUBLIC
  ENROLLED
  PREMIUM
}

// ============================================
// LEARNING PATHS
// ============================================

model LearningPath {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String?  @db.Text
  thumbnailUrl String?
  difficulty   DifficultyLevel @default(BEGINNER)
  estimatedHours Int?
  status       CourseStatus @default(DRAFT)
  featured     Boolean  @default(false)
  orderIndex   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  courses LearningPathCourse[]
  enrollments LearningPathEnrollment[]

  @@map("learning_paths")
}

model LearningPathCourse {
  id              String   @id @default(cuid())
  learningPathId  String
  courseId        String
  orderIndex      Int      @default(0)
  isRequired      Boolean  @default(true)

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([learningPathId, courseId])
  @@map("learning_path_courses")
}

// ============================================
// ENROLLMENTS & PROGRESS
// ============================================

model Enrollment {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  progressPercent Int      @default(0)
  completed       Boolean  @default(false)
  completedAt     DateTime?
  enrolledAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model LearningPathEnrollment {
  id              String   @id @default(cuid())
  userId          String
  learningPathId  String
  progressPercent Int      @default(0)
  completed       Boolean  @default(false)
  completedAt     DateTime?
  enrolledAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  @@unique([userId, learningPathId])
  @@map("learning_path_enrollments")
}

model LearningProgress {
  id           String   @id @default(cuid())
  userId       String
  courseId     String
  lessonId     String
  completed    Boolean  @default(false)
  watchTime    Int      @default(0) // in seconds
  lastPosition Int      @default(0) // video position in seconds
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, lessonId])
  @@index([userId])
  @@index([courseId])
  @@map("learning_progress")
}

// ============================================
// CERTIFICATES
// ============================================

model Certificate {
  id               String   @id @default(cuid())
  userId           String
  courseId         String
  certificateUrl   String?
  templateUrl      String?
  signatureUrl     String?
  sealUrl          String?
  verificationCode String   @unique
  grade            String?
  issuedAt         DateTime @default(now())
  expiresAt        DateTime?
  status           CertificateStatus @default(ACTIVE)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("certificates")
}

enum CertificateStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model CertificateTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  templateUrl  String
  signatureUrl String?
  sealUrl      String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("certificate_templates")
}

// ============================================
// PAYMENTS & SUBSCRIPTIONS
// ============================================

model Subscription {
  id           String            @id @default(cuid())
  userId       String
  planName     String
  planInterval String            @default("month") // month, year
  price        Decimal           @db.Decimal(10, 2)
  currency     String            @default("USD")
  status       SubscriptionStatus @default(ACTIVE)
  provider     PaymentProvider   @default(STRIPE)
  providerId   String?           @unique
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean      @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

enum PaymentProvider {
  STRIPE
  PAYSTACK
  FLUTTERWAVE
  PAYPAL
}

model Payment {
  id           String         @id @default(cuid())
  userId       String
  courseId     String?
  amount       Decimal        @db.Decimal(10, 2)
  currency     String         @default("USD")
  status       PaymentStatus  @default(PENDING)
  provider     PaymentProvider @default(STRIPE)
  reference    String?        @unique
  providerRef  String?
  description  String?
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  DISPUTED
}

// ============================================
// NEWSLETTER
// ============================================

model Newsletter {
  id          String           @id @default(cuid())
  title       String
  subject     String
  content     String           @db.Text
  status      NewsletterStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  audience    NewsletterAudience @default(ALL_USERS)
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  logs NewsletterLog[]

  @@map("newsletters")
}

enum NewsletterStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum NewsletterAudience {
  ALL_USERS
  STUDENTS
  INSTRUCTORS
  PREMIUM_MEMBERS
  INACTIVE_USERS
  SPECIFIC_COURSES
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  userId      String?  @unique
  email       String   @unique
  subscribed  Boolean  @default(true)
  preferences Json?
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?

  user Profile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("newsletter_subscribers")
}

model NewsletterLog {
  id           String   @id @default(cuid())
  newsletterId String
  subscriberId String?
  email        String
  opened       Boolean  @default(false)
  clicked      Boolean  @default(false)
  bounced      Boolean  @default(false)
  unsubscribed Boolean  @default(false)
  openedAt     DateTime?
  clickedAt    DateTime?
  createdAt    DateTime @default(now())

  newsletter Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)

  @@index([newsletterId])
  @@map("newsletter_logs")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String           @db.Text
  type      NotificationType
  link      String?
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  SYSTEM
  ENROLLMENT
  COURSE_UPDATE
  CERTIFICATE
  PAYMENT
  NEWSLETTER
  ANNOUNCEMENT
  REMINDER
}

// ============================================
// STORAGE
// ============================================

model StorageFile {
  id          String   @id @default(cuid())
  bucket      String
  fileName    String
  fileUrl     String
  fileType    String?
  mimeType    String?
  size        BigInt
  uploadedBy  String
  metadata    Json?
  createdAt   DateTime @default(now())

  uploader Profile @relation(fields: [uploadedBy], references: [id])

  @@index([bucket])
  @@index([uploadedBy])
  @@map("storage_files")
}

// ============================================
// ANALYTICS
// ============================================

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String
  eventName String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("analytics_events")
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  module       String
  resourceType String?
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  status       String?
  metadata     Json?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// WISHLIST
// ============================================

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("wishlists")
}

// ============================================
// SITE SETTINGS
// ============================================

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json?
  group     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}